<% layout("/layouts/boilerplate") %>

    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h2>Booking Confirmation</h2>

            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">
                        <%= booking.listing.title %>
                    </h5>
                    <p><strong>Location:</strong>
                        <%= booking.listing.location %>, <%= booking.listing.country %>
                    </p>
                    <hr>
                    <p><strong>Check-in:</strong>
                        <%= booking.checkIn.toDateString() %>
                    </p>
                    <p><strong>Check-out:</strong>
                        <%= booking.checkOut.toDateString() %>
                    </p>
                    <p><strong>Guests:</strong>
                        <%= booking.guests %>
                    </p>
                    <hr>
                    <h4><strong>Total Price:</strong> ₹<%= booking.totalPrice.toLocaleString("en-IN") %>
                    </h4>
                    <p class="text-muted">Status: <%= booking.status %>
                    </p>
                </div>
            </div>

            <a href="/my-bookings" class="btn btn-primary">View All Bookings</a>
        </div>
    </div>